# ============================================
# MCP Atlassian Server - Environment Configuration Template
# ============================================
# Copy this file to .env or env.yaml and replace all placeholder values
# with your actual configuration. Do not commit actual credentials to version control.

# ============================================
# Application Configuration
# ============================================
# Application port (default: 8000 for HTTP transport)
APP_PORT=8000

# ============================================
# Jira Configuration (Required)
# ============================================
# Your Jira instance URL
# Example: https://jira.ringcentral.com/ or https://your-company.atlassian.net
# JIRA_URL=https://your-company.atlassian.net

# Jira Personal Access Token (for Server/DC)
# Generate from: Jira → Account Settings → Security → API Tokens
# Example: ATATT3xFfGF0... (your actual token)
# JIRA_PERSONAL_TOKEN=ATATT3xFfGF0UAJPKskY8A1aeUuh1aS5Qi0JLjJNh7RSCZyZduDTJgPKoQ8h9Bh3sqrEEaNZhjXn42-Mt9pgEl78DP7u93oc8WIGxs5hWtrwzwMLjs-WydJokUvgv3c5TSahIp_WaLNiRDTiC7QQDHNRHdOG04CINieR9VRVqpVDTABf7ql8YWI=708B2E16

# SSL Verification (set to false if using self-signed certificates)
# Example: false or true
JIRA_SSL_VERIFY=false

# ============================================
# Jira Cloud Configuration (Alternative to Personal Token)
# ============================================
# Uncomment and use these if using Jira Cloud instead of Personal Token:
JIRA_URL=https://akadeep6040.atlassian.net/
JIRA_USERNAME=akadeep6040@gmail.com
JIRA_API_TOKEN=ATATT3xFfGF0UAJPKskY8A1aeUuh1aS5Qi0JLjJNh7RSCZyZduDTJgPKoQ8h9Bh3sqrEEaNZhjXn42-Mt9pgEl78DP7u93oc8WIGxs5hWtrwzwMLjs-WydJokUvgv3c5TSahIp_WaLNiRDTiC7QQDHNRHdOG04CINieR9VRVqpVDTABf7ql8YWI=708B2E16

# ============================================
# MCP Server Configuration
# ============================================
# Transport type: stdio, sse, or streamable-http
# Default: stdio (for local), streamable-http (for Cloud Run)
TRANSPORT=streamable-http

# MCP Verbose logging (set to true for debug logs)
MCP_VERBOSE=true

# MCP Jira Agent ID (identifier for this agent instance)
MCP_JIRA_AGENT_ID=mcp-jira-agent-v1

# ============================================
# Google Cloud Platform Configuration (Optional)
# ============================================
# GCP Project ID (for Gemini Vertex AI if using LLM features)
# Example: your-project-id-123
GCP_PROJECT_ID=your-gcp-project-id

# GCP Location/Region (default: us-central1)
# Example: us-central1, us-east1, europe-west1
GCP_LOCATION=us-central1

# Google Application Credentials (path to service account JSON file)
# Example: /path/to/credentials.json
# Leave empty if using default authentication
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/credentials.json

# ============================================
# LLM Temperature Configuration (Optional)
# ============================================
# Temperature values for different LLM tasks (0.0 to 1.0)
# Lower = more deterministic, Higher = more creative

# JQL Generation Temperature (default: 0.1)
LLM_TEMPERATURE_JQL_GENERATION=0.1

# Intent Detection Temperature (default: 0.1)
LLM_TEMPERATURE_INTENT_DETECTION=0.1

# History Decision Temperature (default: 0.2)
LLM_TEMPERATURE_HISTORY_DECISION=0.2

# Query Enrichment Temperature (default: 0.4)
LLM_TEMPERATURE_QUERY_ENRICHMENT=0.4

# Response Formatting Temperature (default: 0.3)
LLM_TEMPERATURE_RESPONSE_FORMATTING=0.3

# ============================================
# Enabled Tools Configuration (Optional)
# ============================================
# Comma-separated list of Jira tools to enable
# Leave empty or omit to enable all tools
# Example: jira_get_user_profile,jira_get_issue,jira_search
ENABLED_TOOLS=jira_get_user_profile,jira_get_issue,jira_search,jira_search_fields,jira_get_project_issues,jira_get_transitions,jira_get_worklog,jira_download_attachments,jira_get_agile_boards,jira_get_board_issues,jira_get_sprints_from_board,jira_get_sprint_issues,jira_get_epics

# ============================================
# Security & Mode Configuration
# ============================================
# Read-only mode (set to true to disable write operations)
# Example: true or false
READ_ONLY_MODE=true

# Use MCP Client (set to true to use MCP protocol)
USE_MCP_CLIENT=true

# ============================================
# Notes
# ============================================
# - Replace all placeholder values (your-*, /path/to/*) with actual values
# - Do not commit this file with actual credentials to version control
# - For Jira Cloud, use JIRA_USERNAME + JIRA_API_TOKEN instead of JIRA_PERSONAL_TOKEN
# - For Jira Server/DC, use JIRA_PERSONAL_TOKEN
# - For Cloud Run deployment, use env-vars.yaml format (see DEPLOY_JIRA_SERVER.sh)
# - Transport type 'stdio' is for local development, 'streamable-http' for Cloud Run
# - See CREDENTIALS_SETUP.md for details on service account JSON file setup
